{
  "project": {
    "name": "idea-dummy-app",
    "app_repo_url": "https://github.com/example/idea-dummy-app.git",
    "git_ref": "main",
    "repo_access_secret_ref": "github-repo-token"
  },
  "build": {
    "source_strategy": "platform_build_runner",
    "frontend_context": "frontend",
    "frontend_dockerfile_path": "frontend/Dockerfile",
    "backend_context": "backend",
    "backend_dockerfile_path": "backend/Dockerfile"
  },
  "argo": {
    "project_name": "default",
    "destination_name": "aws-eks-dev",
    "destination_server": "https://kubernetes.default.svc",
    "gitops_repo_url": "https://github.com/example/idea-gitops.git",
    "gitops_repo_branch": "main",
    "gitops_repo_path": "workloads/idea-dummy-app",
    "gitops_repo_access_secret_ref": "gitops-repo-token"
  },
  "targets": {
    "dev": {
      "provider": "aws",
      "cluster_type": "eks",
      "namespace": "idea-dummy-dev",
      "service_port": 80,
      "aws": {
        "region": "ap-northeast-2",
        "account_id": "123456789012",
        "auth_method": "access_key",
        "access_key_secret_ref": "aws-dev-access-key",
        "secret_key_secret_ref": "aws-dev-secret-key",
        "cluster_name": "idea-dev"
      }
    },
    "stage": {
      "provider": "aws",
      "cluster_type": "eks",
      "namespace": "idea-dummy-stage",
      "service_port": 80,
      "aws": {
        "region": "ap-northeast-2",
        "account_id": "123456789012",
        "auth_method": "assume_role",
        "role_arn": "arn:aws:iam::123456789012:role/idea-stage-deployer",
        "cluster_name": "idea-stage"
      }
    },
    "prod": {
      "provider": "aws",
      "cluster_type": "eks",
      "namespace": "idea-dummy-prod",
      "service_port": 80,
      "aws": {
        "region": "ap-northeast-2",
        "account_id": "123456789012",
        "auth_method": "assume_role",
        "role_arn": "arn:aws:iam::123456789012:role/idea-prod-deployer",
        "cluster_name": "idea-prod"
      }
    }
  },
  "routing": {
    "dev_hostname": "dev.rnen.kr",
    "stage_hostname": "stage.rnen.kr",
    "prod_hostname": "idea.rnen.kr",
    "entry_service_name": "frontend",
    "backend_service_name": "backend",
    "backend_base_path": "/api"
  },
  "env": {
    "dev": {
      "APP_ENV": "dev",
      "APP_DISPLAY_NAME": "Idea Time Sample Dev",
      "PUBLIC_API_BASE_URL": "/api"
    },
    "stage": {
      "APP_ENV": "stage",
      "APP_DISPLAY_NAME": "Idea Time Sample Stage",
      "PUBLIC_API_BASE_URL": "/api"
    },
    "prod": {
      "APP_ENV": "prod",
      "APP_DISPLAY_NAME": "Idea Time Sample Prod",
      "PUBLIC_API_BASE_URL": "/api"
    }
  },
  "secrets": {
    "dev": {
      "DATABASE_URL": "secret://idea-time-dev-database-url"
    },
    "stage": {
      "DATABASE_URL": "secret://idea-time-stage-database-url"
    },
    "prod": {
      "DATABASE_URL": "secret://idea-time-prod-database-url"
    }
  },
  "access": {
    "admin_allowed_source_ips": [
      "58.123.221.76/32"
    ],
    "dev_allowed_source_ips": [
      "58.123.221.76/32"
    ],
    "stage_allowed_source_ips": [
      "58.123.221.76/32"
    ]
  },
  "delivery": {
    "prod_blue_green_enabled": true,
    "healthcheck_path": "/api/healthz",
    "healthcheck_timeout_seconds": 30,
    "rollback_on_failure": true
  }
}
